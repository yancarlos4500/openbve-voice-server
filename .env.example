PORT=8080
HTTPS=false
# SSL_KEY_PATH=./certs/localhost+2-key.pem
# SSL_CERT_PATH=./certs/localhost+2.pem

# Security
# AUTH_PASSWORD=change-me
# SESSION_SECRET=replace-with-long-random-secret
# SESSION_TTL_SECONDS=43200
# ALLOWED_ORIGINS=https://radio.yourdomain.com,https://www.radio.yourdomain.com
# ALLOWED_IPS=203.0.113.10,198.51.100.23
# REQUIRE_HTTPS=true
# TRUST_PROXY=true
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_AUTH_MAX=10
# RATE_LIMIT_WS_MAX=60

# Legacy access token mode (optional)
# ACCESS_TOKEN=legacy-shared-token
